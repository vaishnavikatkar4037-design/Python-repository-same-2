import streamlit as st

st.title("Student Result Calculator")

# Marks input
sub1 = st.number_input("Enter marks for Subject 1", min_value=0, max_value=100)
sub2 = st.number_input("Enter marks for Subject 2", min_value=0, max_value=100)
sub3 = st.number_input("Enter marks for Subject 3", min_value=0, max_value=100)

if st.button("Calculate Result"):
    total = sub1 + sub2 + sub3
    percentage = total / 3

    st.write(f"Total Marks = {total}")
    st.write(f"Percentage = {percentage:.2f}%")

    if percentage >= 35:
        st.success("Result: Pass")
    else:
        st.error("Result: Fail")

        output 
        Subject 1 = 80
Subject 2 = 75
Subject 3 = 90

Total Marks = 245
Percentage = 81.67%
Result: Pass



